{
  "$schema": "https://kickinit.se/schemas/tokens/v1",
  "version": "1.0.0",
  "brand": "KickinIT",
  "colors": {
    "_format": "hsl",
    "_note": "All colors as HSL strings (no hsl() wrapper). Both Tailwind v3 and v4 can consume.",
    "primary": "210 90% 50%",
    "primary-foreground": "0 0% 100%",
    "accent": "32 95% 55%",
    "accent-foreground": "0 0% 10%",
    "background": "0 0% 100%",
    "foreground": "222 47% 11%",
    "muted": "210 40% 96%",
    "muted-foreground": "215 16% 47%",
    "border": "214 32% 91%",
    "destructive": "0 84% 60%",
    "success": "142 71% 45%"
  },
  "typography": {
    "display": "'Space Grotesk', system-ui, sans-serif",
    "body": "'Inter', system-ui, sans-serif",
    "mono": "'JetBrains Mono', ui-monospace, monospace"
  },
  "radii": {
    "sm": "0.375rem",
    "md": "0.5rem",
    "lg": "0.75rem",
    "xl": "1rem"
  },
  "shadows": {
    "sm": "0 1px 2px 0 hsl(222 47% 11% / 0.05)",
    "md": "0 4px 6px -1px hsl(222 47% 11% / 0.1)",
    "lg": "0 10px 15px -3px hsl(222 47% 11% / 0.1)"
  },
  "spacing_scale": "tailwind-default"
}
